		"name": "Partner Hotel API - Testing Collection",
		"description": "Collection for testing the Partner Hotel API. Created for QA purposes.\nCovers happy paths, edge cases and error scenarios.\n\nBase URL is stored in the environment variables so you can easily switch between local and production.\n\nNote: Remember to select the right environment before running!",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Happy Paths",
			"description": "These are the normal use cases - the ones that should always work",
			"item": [
				{
					"name": "Get All Hotels",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// basic check - is the response OK?",
									"pm.test(\"Status code should be 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response should have hotels array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.hotels).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Hotels array should not be empty\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.hotels.length).to.be.above(0);",
									"});",
									"",
									"pm.test(\"Each hotel should have a propertyId\", function () {",
									"    var jsonData = pm.response.json();",
									"    jsonData.hotels.forEach(function(hotel) {",
									"        pm.expect(hotel.propertyId).to.exist;",
									"    });",
									"});",
									"",
									"pm.test(\"Each hotel should have localTime field\", function () {",
									"    var jsonData = pm.response.json();",
									"    jsonData.hotels.forEach(function(hotel) {",
									"        pm.expect(hotel.localTime).to.exist;",
									"    });",
									"});",
									"",
									"// save total count for later use maybe",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"total_hotels\", jsonData.hotels.length);",
									"console.log(\"Total hotels found: \" + jsonData.hotels.length);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/partner/hotels",
							"host": ["{{base_url}}"],
							"path": ["api", "partner", "hotels"]
						},
						"description": "Gets all hotels from the API. Should return all 14 hotels."
					}
				},
				{
					"name": "Search Hotels by Name - Taj",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Should return hotels with Taj in the name\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.hotels.length).to.be.above(0);",
									"    jsonData.hotels.forEach(function(hotel) {",
									"        pm.expect(hotel.propertyName.toLowerCase()).to.include('taj');",
									"    });",
									"});",
									"",
									"pm.test(\"Response time should be less than 2000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript"
							}
