				{
					"name": "Get Hotel by ID - 204 (Italy)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Returns correct hotel\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.propertyId).to.eql('204');",
									"    pm.expect(jsonData.propertyName).to.eql('Hotel Roma Palace');",
									"    pm.expect(jsonData.country).to.eql('Italy');",
									"});",
									"",
									"pm.test(\"Local time should be in Italy timezone\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.localTime).to.exist;",
									"    pm.expect(jsonData.localTime).to.be.a('string');",
									"});",
									"",
									"pm.test(\"Payment details should exist and have all fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.paymentDetails).to.exist;",
									"    pm.expect(jsonData.paymentDetails.paymentModel).to.exist;",
									"    pm.expect(jsonData.paymentDetails.cvc).to.exist;",
									"    pm.expect(jsonData.paymentDetails.creditCardsAccepted).to.exist;",
									"    pm.expect(jsonData.paymentDetails.vccStatus).to.exist;",
									"});",
									"",
									"pm.test(\"KYP object should exist with all 4 fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.kyp).to.exist;",
									"    pm.expect(jsonData.kyp.bhfs).to.exist;",
									"    pm.expect(jsonData.kyp.dac7).to.exist;",
									"    pm.expect(jsonData.kyp.dsa).to.exist;",
									"    pm.expect(jsonData.kyp.serr).to.exist;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
